# ==============================================================================
# ProfitEngine - DegenTerminal 雙雄平行對決與幣安自動發文變現系統配置範本
# ==============================================================================

# --- 1. Solana 區塊鏈與錢包安全配置 ---
# Solana 主網 RPC 節點連結，建議使用 Helius、QuickNode 等低延遲付費/免費端點，防止頻率限制
RPC_URL=https://api.mainnet-beta.solana.com

# 智能體角色設定 JSON 檔案路徑 (預設為 characters 目錄下的檔案)
CHARACTER_FILE=profitengine.character.json

# 本地加密熱錢包的密鑰解密 Key。請填寫強密碼，保護您的交易資金安全
WALLET_SECRET=ProfitEngineAutonomousCryptoKey2026

# --- 2. 幣安自動寫文章與 Write-to-Earn (寫作返傭) 配置 ---
# 幣安創作者中心 (Square Creator Center) 申請的 OpenAPI 密鑰
# 僅需開通 "Content Publishing / 內容發布" 權限，無交易、資金劃轉權限，物理隔離保證 100% 安全
# 使用官方 Square Post Skill API，支援多圖上傳、文章標題、封面圖片 (presigned upload + polling)
BINANCE_SQUARE_OPENAPI_KEY=your_binance_square_openapi_key_here
# 向下相容舊版變數名稱 (擇一填寫即可)
# BINANCE_SQUARE_API_KEY=your_binance_square_openapi_key_here

# 您的幣安 Square 創作者 Handle (個人主頁帳號名稱，例如 "SilicDadCrypto")
# 用於生成導流連結。如果不填寫，系統將默認使用下方的推薦連結
BINANCE_SQUARE_CREATOR_HANDLE=your_square_handle_here

# 您的幣安推薦註冊連結 (Binance Referral / Affiliate Link)
# 外部平台 (X, Medium, TG) 用戶點擊該連結註冊並交易，你將賺取高達 40% ~ 50% 終身手續費返傭
BINANCE_REFERRAL_LINK=https://www.binance.com/zh-TC/activity/referral-entry/MY_REFERRAL_CODE

# --- 3. 跨平台推廣與流量變現渠道配置 ---

# X (Twitter) 自動化瀏覽器配置 (使用原有 Headless Chrome 登錄態)
# 系統將自動抓取 Square 長文並智能截斷為 X.com 的 teaser 短文進行導流

# [Telegram 頻道推送]
# 申請一個 Telegram Bot 獲取 Token (@BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# 接收推送的 Channel ID 或 Group ID (例如 "-1001234567890")
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# [Medium 深度 SEO 長文發布]
# 於 Medium 設置頁面 (Settings -> Integration tokens) 獲取的 API 密鑰
MEDIUM_API_TOKEN=your_medium_integration_token_here
# 您的 Medium 使用者 ID (可透過 GET https://api.medium.com/v1/me 查詢)
MEDIUM_AUTHOR_ID=your_medium_author_id_here

# --- 5. LLM 文章生成 (DeepSeek) 配置 ---
# 使用 DeepSeek API 根據角色設定 (aria.character.json) 自動生成更簡潔、多變的幣安 Square 文章
# 若未設定則自動降級為傳統範本生成 (向後相容)
# 申請 DeepSeek API Key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
